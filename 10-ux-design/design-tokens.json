    "4": { "value": "16px" },
    "5": { "value": "20px" },
    "6": { "value": "24px" },
    "7": { "value": "28px" },
    "8": { "value": "32px" },
    "14": { "value": "56px" },
    "15": { "value": "60px" },
    "20": { "value": "80px" }
  },
  "typography": {
    "fontFamily": {
      "sans": { "value": "-apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif" }
    },
    "fontSize": {
      "xs": { "value": "13px" },
      "sm": { "value": "14px" },
