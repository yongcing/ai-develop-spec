{
  "$schema": "https://design-tokens.org/schema.json",
  "$source": "Extracted from prototypes/V0_Covenant Data Platform.html",
  "color": {
    "brand": {
      "primary": { "value": "#0071e3", "comment": "主要互動色（Apple blue）" },
      "accent": { "value": "#5856d6", "comment": "輔助強調色" }
    },
    "neutral": {
      "0": { "value": "#ffffff" },
      "50": { "value": "#f5f5f7", "comment": "頁面背景" },
      "100": { "value": "#ececee" },
      "200": { "value": "#eeeeee" },
      "300": { "value": "#dddddd" },
      "400": { "value": "#cccccc" },
      "600": { "value": "#999999" },
      "700": { "value": "#666666" },
      "800": { "value": "#3a3a3c" },
      "900": { "value": "#2c2c2e" },
      "950": { "value": "#1d1d1f", "comment": "主要文字" }
    },
    "semantic": {
      "success": { "value": "#248a3d" },
      "warning": { "value": "#e37400" },
      "warningStrong": { "value": "#bf5600" },
      "error": { "value": "#e30000" },
      "errorBg": { "value": "#ff8a80" },
      "info": { "value": "#64d2ff" }
